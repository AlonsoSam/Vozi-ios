// LocalSecrets.example.xcconfig
// PLANTILLA de credenciales locales para la evaluación avanzada
// (Azure Pronunciation Assessment, BLOQUE 2B). NO contiene secretos reales.
// Este archivo SÍ se versiona; sirve como referencia.
//
// Uso:
//   1. Copia este archivo como `LocalSecrets.xcconfig` (mismo directorio).
//   2. Pega tu clave real SOLO en AZURE_SPEECH_KEY de `LocalSecrets.xcconfig`.
//   3. `LocalSecrets.xcconfig` está en .gitignore: nunca se sube al repo.
//
// Privacidad: las keys viven solo en el archivo local, nunca en código ni en git.

// Pega aquí tu clave (solo en LocalSecrets.xcconfig, no en esta plantilla).
AZURE_SPEECH_KEY =

AZURE_SPEECH_REGION = eastus

// Nota xcconfig: "//" inicia un comentario. Para no truncar la URL, el esquema
// https se arma con $() (que evalúa a cadena vacía). El valor final resultante
// es: https://eastus.api.cognitive.microsoft.com/
AZURE_SPEECH_ENDPOINT = https:/$()/eastus.api.cognitive.microsoft.com/
